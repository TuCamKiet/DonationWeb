# # Neon Postgres connection string (libpq format; the app converts it for asyncpg)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require
# Secret used to sign JWT access tokens — change in production
JWT_SECRET=your_super_secret_jwt_key_here
# # OAuth 2.0 Client ID from Google Cloud Console (same one the frontend uses)
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Database Configuration (PostgreSQL/Neon)
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host/your_db_name?sslmode=require&channel_binding=require
# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Security / CORS
CORS_ORIGINS=["https://your-frontend.vercel.app", "http://localhost:5173"]
#Send email for order by RESEND
RESEND_API_KEY=re_abcxyz123456789